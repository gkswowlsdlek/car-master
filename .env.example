# 개발 데모는 외부 서비스 없이 동작합니다.
# 실제 회원 시스템 값은 .env.local과 Vercel 환경변수에만 입력하세요.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
